# ════════════════════════════════════════════════════════════
#  TrustControl — Переменные окружения
#  Скопируй в .env и заполни реальными значениями
#  cp .env.example .env
# ════════════════════════════════════════════════════════════

# Сервер
PORT=8000
DEBUG=false

# SECURITY: сгенерируй командой: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замени-на-случайную-строку-минимум-64-символа

# OpenAI (для Whisper транскрипции)
OPENAI_API_KEY=sk-proj-...

# Anthropic (для AI бота)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram бот
TELEGRAM_BOT_TOKEN=7123456789:AAF-...

# База данных (SQLite для старта, PostgreSQL для продакшна)
DATABASE_URL=sqlite+aiosqlite:///trustcontrol.db
# DATABASE_URL=postgresql+asyncpg://tc_user:tc_pass@localhost/trustcontrol

# Kaspi оплата
KASPI_NUMBER=+7 (XXX) XXX-XX-XX
KASPI_NAME=Данил Т.

# Язык распознавания по умолчанию
WHISPER_LANGUAGE=ru

# CORS — домены которым разрешён доступ к API (через запятую)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

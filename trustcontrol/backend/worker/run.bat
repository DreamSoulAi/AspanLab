@echo off
chcp 65001 >nul

REM ════════════════════════════════════════════════════════════
REM  TrustControl — Запуск воркера (кассовый ПК)
REM
REM  НАСТРОЙКА: Замени значения ниже на свои данные.
REM  API-ключ берётся на сайте: Точки → ваша точка → скопировать ключ
REM ════════════════════════════════════════════════════════════

set API_URL=https://aspanlab-1.onrender.com
set API_KEY=ВАШ_API_КЛЮЧ_ЗДЕСЬ

REM ── Проверка конфига ─────────────────────────────────────────
if "%API_KEY%"=="ВАШ_API_КЛЮЧ_ЗДЕСЬ" (
    echo.
    echo [ОШИБКА] Не заполнен API_KEY в файле run.bat!
    echo.
    echo Откройте файл run.bat в Блокноте и замените:
    echo   ВАШ_API_КЛЮЧ_ЗДЕСЬ
    echo на настоящий ключ из личного кабинета.
    echo.
    pause
    exit /b 1
)

echo ╔══════════════════════════════════════════════════════════╗
echo ║         TrustControl — Мониторинг запущен               ║
echo ╚══════════════════════════════════════════════════════════╝
echo.
echo Сервер : %API_URL%
echo API KEY: %API_KEY:~0,8%...
echo.
echo Для остановки нажмите Ctrl+C
echo.

py -3.13 monitor.py --api-url "%API_URL%" --api-key "%API_KEY%"

echo.
echo Воркер остановлен.
pause

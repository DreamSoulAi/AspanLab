@echo off
chcp 65001 >nul

REM ════════════════════════════════════════════════════════════
REM  TrustControl — Настройка автозапуска Windows
REM
REM  Запускай этот файл ОДИН РАЗ от имени администратора.
REM  После этого монитор будет стартовать автоматически при входе в Windows.
REM ════════════════════════════════════════════════════════════

echo ╔══════════════════════════════════════════════════════════╗
echo ║      TrustControl — Настройка автозапуска               ║
echo ╚══════════════════════════════════════════════════════════╝
echo.

REM Полный путь к run.bat (берём из папки где лежит этот файл)
set RUN_BAT="%~dp0run.bat"

REM Проверяем что run.bat существует
if not exist %RUN_BAT% (
    echo [ОШИБКА] Файл run.bat не найден рядом с этим файлом!
    pause
    exit /b 1
)

REM Удаляем старую задачу если была
schtasks /delete /tn "TrustControl Monitor" /f >nul 2>&1

REM Создаём задачу: запускать run.bat при входе в систему
schtasks /create ^
    /tn "TrustControl Monitor" ^
    /tr %RUN_BAT% ^
    /sc onlogon ^
    /ru "%USERNAME%" ^
    /rl highest ^
    /f

if errorlevel 1 (
    echo.
    echo [ОШИБКА] Не удалось создать задачу.
    echo Попробуй запустить этот файл от имени администратора:
    echo ПКМ на файл → "Запуск от имени администратора"
    echo.
    pause
    exit /b 1
)

echo.
echo ╔══════════════════════════════════════════════════════════╗
echo ║  Готово! Автозапуск настроен.                           ║
echo ║                                                          ║
echo ║  Монитор будет запускаться автоматически                 ║
echo ║  при каждом входе в Windows.                             ║
echo ║                                                          ║
echo ║  Управление: Диспетчер задач → Автозагрузка             ║
echo ║  или: Планировщик задач → TrustControl Monitor           ║
echo ╚══════════════════════════════════════════════════════════╝
echo.
pause

# ════════════════════════════════════════════════════════════
#  TrustControl — ПРОД env для VPS (ps.kz, Алматы)
#  Скопировать на сервере:  cp .env.prod.example .env.prod
#  Заполнить РЕАЛЬНЫМИ значениями (те же, что стояли в Render).
#  Файл .env.prod в .gitignore — в репозиторий НЕ коммитим.
# ════════════════════════════════════════════════════════════

# ── Обязательные ──────────────────────────────────────────
SECRET_KEY=                       # тот же, что был в Render (иначе разлогинит всех)
OPENAI_API_KEY=sk-proj-...
TELEGRAM_BOT_TOKEN=

# БД оставляем на Neon — берём DATABASE_URL из Render как есть
DATABASE_URL=postgresql+asyncpg://...neon.tech/...

# CORS — наш домен
ALLOWED_ORIGINS=https://trustcontrol.kz,https://www.trustcontrol.kz

# ── ISSAI воркер (он на ЭТОМ же VPS, порт 8010) ──────────
# Внутри docker сети api↔issai по IP хоста или host.docker.internal.
# Проще всего — реальный IP VPS, как и было в Render:
ISSAI_WORKER_URL=http://213.155.21.25:8010
ISSAI_WORKER_KEY=

# ── Аудио-архив Cloudflare R2 (как в Render) ─────────────
S3_BUCKET=trustcontrol-audio
S3_ENDPOINT_URL=
S3_PUBLIC_URL=
S3_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Прочее (как в Render) ────────────────────────────────
OTP_BYPASS=true
ADMIN_TELEGRAM_CHAT=
DEBUG=false

# ════════════════════════════════════════════════════════════
#  TrustControl — Переменные окружения
#  Скопируй в .env и заполни реальными значениями
#  cp .env.example .env
# ════════════════════════════════════════════════════════════

# Сервер
PORT=8000
DEBUG=false

# SECURITY: сгенерируй командой: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замени-на-случайную-строку-минимум-64-символа

# OpenAI (для Whisper транскрипции)
OPENAI_API_KEY=sk-proj-...

# Anthropic (для AI бота)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram бот
TELEGRAM_BOT_TOKEN=7123456789:AAF-...

# База данных (SQLite для старта, PostgreSQL для продакшна)
DATABASE_URL=sqlite+aiosqlite:///trustcontrol.db
# DATABASE_URL=postgresql+asyncpg://tc_user:tc_pass@localhost/trustcontrol

# S3 / Supabase Storage (архив приоритетных записей, priority=1)
# Оставь пустым если S3 не нужен — SHA-256 всё равно сохранится в БД
S3_BUCKET=
S3_REGION=us-east-1
# Для Supabase: https://<project>.supabase.co/storage/v1/s3
# Для MinIO:    http://localhost:9000
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Kaspi оплата
KASPI_NUMBER=+7 (XXX) XXX-XX-XX
KASPI_NAME=Данил Т.

# Язык распознавания по умолчанию
WHISPER_LANGUAGE=ru

# ── ISSAI STT — self-hosted faster-whisper (лучший вариант для казахского) ──
# Модель: abilmansplus/whisper-turbo-ksc2 (9.16% WER, KSC2 + шала-казахский)
# Запустить воркер: docker-compose -f docker-compose.issai.yml up -d
# Затем задать URL и (опционально) API-ключ:
ISSAI_WORKER_URL=
# Например: http://your-vps-ip:8010 или http://issai-worker:8010 (Docker)
ISSAI_WORKER_KEY=
# Должен совпадать с ISSAI_API_KEY на воркере. Если пусто — без авторизации.

# Масштабирование:
#   2-3 кассы  → 1 CPU VPS (4 ядра, 4GB RAM), 1 воркер
#   10-30 касс → 1 GPU VPS (RTX 3060) или 2-3 CPU воркера за nginx
#   50-100 касс → GPU (RTX 3090/4090) + CPU резерв

# ── Yandex SpeechKit STT (точное распознавание казахского) ──────────
# Если заданы оба значения — включается гибрид: точные казахские слова
# от Yandex + тон голоса от аудио-модели OpenAI. Если пусто — работает
# только OpenAI (казахский распознаётся хуже).
# Как получить: Yandex Cloud → IAM → Сервисный аккаунт (роль ai.speechkit-stt.user)
#   → создать API-ключ; folder id виден на странице каталога.
YANDEX_STT_API_KEY=
YANDEX_STT_FOLDER_ID=
# Язык: kk-KZ (казахский, по умолчанию) | ru-RU | en-US
YANDEX_STT_LANG=kk-KZ

# CORS — домены которым разрешён доступ к API (через запятую)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
